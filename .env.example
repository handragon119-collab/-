# ============================================================
#  인스타그램 AI 자동 업로드 - 환경변수 설정
#  이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요.
#  cp .env.example .env
# ============================================================

# --- 1. 캡션 생성 (Claude / Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# 캡션 생성 모델 (기본값: claude-sonnet-4-6)
CAPTION_MODEL=claude-sonnet-4-6

# --- 2. 이미지 생성 ---
# 사용할 제공자: openai | gemini | placeholder
IMAGE_PROVIDER=placeholder

# (openai 사용 시)
OPENAI_API_KEY=sk-xxxxxxxx
# 이미지 모델: gpt-image-1 또는 dall-e-3
OPENAI_IMAGE_MODEL=gpt-image-1

# (gemini 사용 시)
GEMINI_API_KEY=xxxxxxxx

# --- 3. 인스타그램 업로드 ---
# 업로드 방식: instagrapi | graph | none(업로드 안함)
PUBLISHER=none

# (instagrapi 방식 - 일반 개인 계정)
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# (graph 방식 - 비즈니스/크리에이터 계정 + Facebook 앱 필요)
IG_GRAPH_ACCESS_TOKEN=EAAxxxxxxxx
IG_GRAPH_USER_ID=1784xxxxxxxx
# graph 방식은 공개 이미지 URL이 필요합니다. 업로드한 이미지의 공개 URL을 넣거나
# 자동 호스팅을 구성하세요. (아래 PUBLIC_IMAGE_BASE_URL 참고)
PUBLIC_IMAGE_BASE_URL=
