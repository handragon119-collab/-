# ============================================================
#  인스타그램 AI 자동 업로드 - 환경변수 설정
#  cp .env.example .env  후 값을 채우세요.
# ============================================================

# ============================================================
#  [A] 완전 무료 구성  (캡션=Gemini 무료등급, 이미지=Pollinations)
#  아래 주석을 해제해서 쓰세요. 비용 $0.
# ============================================================
# CAPTION_PROVIDER=gemini
# GEMINI_API_KEY=xxxxxxxx          # Google AI Studio 무료 발급
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# IMAGE_PROVIDER=pollinations
# POLLINATIONS_TOKEN=              # auth.pollinations.ai 무료 발급(권장, 워터마크 제거/한도↑)
# IMAGE_ASPECT_RATIO=1:1

# ============================================================
#  [B] 유료 고품질 구성 (캡션=Claude, 이미지=Gemini 유료)  ← 현재 기본값
# ============================================================
CAPTION_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
CAPTION_MODEL=claude-sonnet-4-6

IMAGE_PROVIDER=gemini
GEMINI_API_KEY=xxxxxxxx
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
IMAGE_ASPECT_RATIO=1:1

# ============================================================
#  콘텐츠 형식
# ============================================================
# cardnews(카드뉴스 캐러셀) | photo(단일 AI 사진)
CONTENT_MODE=cardnews
# 생성 엔진: simple(단일 프롬프트) | agentic(7-에이전트 고급, 리서치·팩트검증·SEO·리스크)
CONTENT_ENGINE=simple
# 카드뉴스 본문 카드 개수 (표지/마무리 제외)
CARD_COUNT=6
# 카드 색상 테마: navy | mint | coral | cream | luxe(고급 명조)
CARD_THEME=navy
# 카드 크기 (인스타 추천: 1080x1350 = 4:5)
CARD_SIZE=1080x1350
# 카드 하단에 표시할 계정 핸들 (선택)
BRAND_HANDLE=@my_account

# ============================================================
#  인스타그램 업로드 (비즈니스 / Graph API) - 무료
# ============================================================
PUBLISHER=graph
IG_GRAPH_ACCESS_TOKEN=EAAxxxxxxxx
IG_GRAPH_USER_ID=1784xxxxxxxx

# 이미지 공개 호스팅 (Graph API에 필요) - imgbb 무료
IMAGE_HOST=imgbb
IMGBB_API_KEY=xxxxxxxx
PUBLIC_IMAGE_BASE_URL=

OUTPUT_DIR=output
