# 이 파일을 복사해서 .env 로 이름을 바꾸고 값을 채우세요.
# cp .env.example .env

# Claude API 키 (https://console.anthropic.com 에서 발급)
# 없으면 자비스는 기본 명령어만 처리하는 '규칙 기반' 모드로 동작합니다.
ANTHROPIC_API_KEY=

# 사용할 Claude 모델 (기본값으로 충분합니다)
JARVIS_MODEL=claude-sonnet-4-6

# 깨우는 방식: clap = 박수로 깨우기(기본), word = 호출어로 깨우기
JARVIS_WAKE_MODE=clap

# 박수 감지 민감도 (안 깨어나면 숫자를 낮추고, 너무 자주 깨면 높이세요)
# JARVIS_CLAP_THRESHOLD = 고정 임계값(예: 2500). 비우면 주변소음 기반 자동.
# JARVIS_CLAP_MULT = 주변소음 대비 몇 배를 박수로 볼지 (기본 6, 낮추면 더 민감)
JARVIS_CLAP_THRESHOLD=
JARVIS_CLAP_MULT=6

# 호출 이름 (word 모드일 때 이 단어로 깨웁니다)
JARVIS_WAKE_WORD=자비스

# 음성 인식 언어 (ko-KR = 한국어, en-US = 영어)
JARVIS_LANG=ko-KR

# 깨어날 때 나오는 영어 웰컴 멘트 (영화 자비스 톤)
JARVIS_WELCOME=Good day, sir. J.A.R.V.I.S. online and at your service.

# 깨어날 때 재생할 음악 파일 (없으면 유튜브에서 Back in Black 검색해서 엶)
# 예) JARVIS_WAKE_MUSIC=/home/me/music/back_in_black.mp3
JARVIS_WAKE_MUSIC=

# (선택) 특정 TTS 음성 id를 강제 지정하고 싶을 때.
# 비워두면 영어=영국식 남성(자비스 톤), 한국어=한국어 음성을 자동 선택합니다.
JARVIS_VOICE_EN=
JARVIS_VOICE_KO=

# (선택) OpenWeatherMap API 키 - 날씨 명령에 필요
OPENWEATHER_API_KEY=
