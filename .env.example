# ===== Threads (Meta) 공식 API =====
# https://developers.facebook.com 에서 앱 생성 후 Threads API 권한을 받고 발급
THREADS_USER_ID=여기에_스레드_사용자_ID
THREADS_ACCESS_TOKEN=여기에_장기_액세스_토큰

# ===== Claude API (글 자동 생성) =====
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=여기에_API_키

# ===== 생성 옵션 =====
# 글 생성에 사용할 모델
CLAUDE_MODEL=claude-opus-4-8
# 글의 전반적인 톤/페르소나 (선택)
THREADS_PERSONA=친근하고 진솔한 한국어 톤으로, 과한 이모지나 해시태그 남발 없이 글을 쓴다.
# 한 번 실행 시 생성·게시할 글 개수
POSTS_PER_RUN=1

# ===== 스케줄 옵션 =====
# cron 표현식 (분 시 일 월 요일). 기본: 매일 오전 9시
SCHEDULE_CRON=0 9 * * *
# 타임존
TIMEZONE=Asia/Seoul

# ===== 안전장치 (밴·노출제한 위험 완화) =====
# 24시간 내 최대 게시 수 (공식 한도 약 250개보다 낮게)
DAILY_POST_LIMIT=200
# 한 번 실행에서 여러 글을 올릴 때 글 사이 최소 대기(초)
MIN_POST_INTERVAL_SECONDS=60
# 스케줄 실행 시각에 더할 랜덤 지터(분) - 봇 패턴 회피
SCHEDULE_JITTER_MINUTES=20
# 최근 글과 이 비율 이상 유사하면 중복으로 보고 재생성 (0~1)
DUPLICATE_SIMILARITY_THRESHOLD=0.8
# 중복 검사 시 비교할 최근 글 개수
DUPLICATE_LOOKBACK=30

# ===== 이미지 자동 생성 (선택, 안 쓰면 비워두세요) =====
# 사진을 AI로 만들어 함께 올리고 싶을 때만 채우면 됩니다.
# OpenAI 이미지 생성 키 (Claude는 그림을 못 그려서 별도 서비스 사용)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=
# 이미지 생성 모델 / 크기 (보통 그대로 두면 됨)
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
# Imgur 익명 업로드용 Client-ID (만든 이미지를 인터넷에 올려 주소를 만듦)
# https://api.imgur.com/oauth2/addclient 에서 'Anonymous usage' 선택해 발급
IMGUR_CLIENT_ID=
