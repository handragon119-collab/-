# ============================================================
#  인스타그램 AI 자동 업로드 - 환경변수 설정
#  이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요.
#  cp .env.example .env
#
#  현재 기본 구성: 이미지=Gemini, 업로드=비즈니스(Graph API) + imgbb 호스팅
# ============================================================

# --- 1. 캡션 생성 (Claude / Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
CAPTION_MODEL=claude-sonnet-4-6

# --- 2. 이미지 생성 (Gemini) ---
IMAGE_PROVIDER=gemini
GEMINI_API_KEY=xxxxxxxx
# Nano Banana 이미지 모델
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# 인스타그램 피드용 비율: 1:1(정사각형), 4:5(세로), 9:16(릴스/스토리) 등
IMAGE_ASPECT_RATIO=1:1

# --- 3. 인스타그램 업로드 (비즈니스 / Graph API) ---
PUBLISHER=graph
# Facebook 개발자 앱에서 발급. 인스타그램 비즈니스/크리에이터 계정이 페이스북 페이지와 연결되어 있어야 함.
IG_GRAPH_ACCESS_TOKEN=EAAxxxxxxxx
IG_GRAPH_USER_ID=1784xxxxxxxx

# --- 4. 이미지 공개 호스팅 (Graph API에 필요) ---
# Graph API는 공개 이미지 URL을 요구합니다. imgbb가 가장 간단합니다.
# 방식: imgbb | cloudinary | base_url
IMAGE_HOST=imgbb
# https://api.imgbb.com/ 에서 무료 발급
IMGBB_API_KEY=xxxxxxxx
# (IMAGE_HOST=base_url 인 경우, 이미 공개된 서버/S3의 베이스 URL)
PUBLIC_IMAGE_BASE_URL=

# --- 기타 ---
OUTPUT_DIR=output
