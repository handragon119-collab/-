#!/bin/bash
# 더블클릭하면 웹 UI를 켜고 브라우저를 자동으로 엽니다. (macOS 전용)
# 이 파일이 있는 폴더로 이동
cd "$(dirname "$0")"

echo "=================================================="
echo "  🧵 스레드 자동 업로드 웹앱을 시작합니다…"
echo "  잠시 후 브라우저가 자동으로 열립니다."
echo "  (이 창을 닫으면 웹앱이 꺼집니다)"
echo "=================================================="

# 3초 뒤 브라우저 자동 열기 (서버 켜지는 시간 대기)
( sleep 3; open "http://127.0.0.1:5000" ) &

# 웹 서버 실행
python3 webapp.py
