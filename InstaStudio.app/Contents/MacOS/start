#!/bin/bash
# ─────────────────────────────────────────────
#  인스타 스튜디오 — 더블클릭 실행 앱
#  옛날 서버를 깨끗이 정리하고, 이 폴더의 최신 코드로 서버를 켭니다.
#  (창 없이 백그라운드 실행 + 알림 + 브라우저 자동 열기)
# ─────────────────────────────────────────────

# 이 앱은 프로젝트 폴더 안에 있음:  <프로젝트>/InstaStudio.app/Contents/MacOS/start
cd "$(dirname "$0")/../../.." || exit 1
ROOT="$(pwd)"

notify() { osascript -e "display notification \"$1\" with title \"인스타 스튜디오\"" 2>/dev/null; }
alertbox() { osascript -e "display dialog \"$1\" buttons {\"확인\"} with title \"인스타 스튜디오\"" 2>/dev/null; }

# 0) 옛 자동실행/서버 완전 제거 (옛 코드를 붙잡는 주범)
launchctl unload "$HOME/Library/LaunchAgents/com.instaauto.server.plist" 2>/dev/null
rm -f "$HOME/Library/LaunchAgents/com.instaauto.server.plist"
lsof -ti :8000 2>/dev/null | xargs kill -9 2>/dev/null
pkill -9 -f "web.server" 2>/dev/null
sleep 1

# 1) python3 확인
if ! command -v python3 >/dev/null 2>&1; then
  alertbox "python3 가 필요합니다. python.org 에서 설치한 뒤 다시 실행해 주세요."
  exit 1
fi

# 2) 최초 1회 환경 설치
if [ ! -d "$ROOT/.venv" ]; then
  notify "처음 실행이라 환경을 설치합니다 (1~2분)…"
  python3 -m venv "$ROOT/.venv" || { alertbox "환경 생성 실패"; exit 1; }
  "$ROOT/.venv/bin/python" -m pip install --upgrade pip >/dev/null 2>&1
  "$ROOT/.venv/bin/pip" install -r "$ROOT/requirements.txt" || { alertbox "설치 실패"; exit 1; }
fi

# 3) 백그라운드로 서버 시작 (창 닫아도 유지)
nohup "$ROOT/.venv/bin/python" -m web.server > "$ROOT/web_server.log" 2>&1 < /dev/null &
sleep 4

# 4) 브라우저 열기 + 알림
open "http://localhost:8000"
notify "서버 시작됨 → http://localhost:8000"
